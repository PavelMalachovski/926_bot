# Environment Configuration
ENVIRONMENT=development
DEBUG=true

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=forex_bot
DB_USER=forex_user
DB_PASSWORD=forex_password
DB_URL=postgresql+asyncpg://forex_user:forex_password@localhost:5432/forex_bot

# Redis Configuration (optional — app runs without cache if unavailable)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
# Set to true to make startup fail when Redis is unreachable
REDIS_REQUIRED=false

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/api/v1/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here

# SMC Strategy Watcher (Triple Sync + Imbalance)
SMC_ENABLED=true
SMC_SYMBOL=ETHUSDT
SMC_DISPLAY_SYMBOL=ETHUSD
SMC_INTERVAL_MINUTES=15
SMC_MIN_FVG_USD=2.0
SMC_SL_BUFFER_USD=2.0
SMC_MIN_RR=2.0
SMC_RISK_PCT=2.0
# SMC_DEPOSIT=1000            # optional: deposit in USD for automatic lot hint
SMC_ENFORCE_SESSIONS=true
SMC_NOTIFY_NO_SETUP=true
# SMC_CHAT_ID=                # optional: override TELEGRAM_CHAT_ID for SMC alerts

# API Keys
API_ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here
API_OPENAI_API_KEY=your_openai_api_key_here
API_OPENAI_MODEL=gpt-4o-mini
API_OPENAI_TEMPERATURE=0.25
API_OPENAI_MAX_TOKENS=500
API_OPENAI_ENABLED=true
API_OPENAI_RATE_LIMIT_SECONDS=15

# Security Configuration
SECURITY_SECRET_KEY=your_secret_key_here_minimum_32_characters
SECURITY_ALGORITHM=HS256
SECURITY_ACCESS_TOKEN_EXPIRE_MINUTES=30
SECURITY_REFRESH_TOKEN_EXPIRE_DAYS=7
SECURITY_API_KEY=your_api_key_for_internal_endpoints

# Chart Configuration
CHART_ENABLE_ALPHA_VANTAGE=false
CHART_ENABLE_ALT_SYMBOLS=false
CHART_ALLOW_MOCK_DATA=false
CHART_DISPLAY_TIMEZONE=Europe/Prague
CHART_YF_MIN_REQUEST_INTERVAL_SEC=3.0
CHART_CHART_RETENTION_DAYS=3

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s [%(levelname)s] %(name)s: %(message)s
LOG_FILE_PATH=logs/app.log
LOG_MAX_FILE_SIZE=10485760
LOG_BACKUP_COUNT=5

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=1
